# mycraft .gitignore

# 하네스 중간 산출물 (재생성 가능)
_workspace/
_workspace_prev_*/

# OMC 상태
.omc/state/

# 환경 변수 / 비밀
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# 의존성 (스택 결정 후 정리)
node_modules/
.pnpm-store/
__pycache__/
.venv/
venv/
.uv/

# 빌드 결과물
dist/
build/
.next/
out/
*.tsbuildinfo

# 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 에디터 / OS
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 캐시
.cache/
.parcel-cache/
.eslintcache
.turbo/

# 테스트 / 커버리지
coverage/
.nyc_output/
