# mycraft environment variables — 템플릿
# 실제 값은 .env.local 에 작성 (gitignored). 이 파일은 커밋된다.

# ── Discord (운영 알림 webhook) ───────────────────────────────────────
# 서버 전용 — 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것.
# Discord 채널 설정 > Integrations > Webhooks 에서 발급.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<webhook_id>/<webhook_token>

# ── Supabase ─────────────────────────────────────────────────────────
# https://supabase.com/dashboard 에서 프로젝트 생성 후 Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key__server_only>
# Postgres direct connection (Drizzle 마이그레이션용). Supabase 콘솔 > Settings > Database.
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/postgres

# ── App ──────────────────────────────────────────────────────────────
# 로컬 dev: http://localhost:3000
# 프로덕션: https://<your-domain>.vercel.app  또는 커스텀
NEXT_PUBLIC_APP_URL=http://localhost:3000
